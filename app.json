{
  "expo": {
    "name": "coreflow",
    "slug": "coreflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.241331490609-ru0e1cbhj9eb9g56i2if9009aa8uekff"
            ]
          }
        ]
      },
      "bundleIdentifier": "com.pilates-coreflow.app",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFE9D5"
      },
      "permissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.coreflow.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFE9D5"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload them."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Apple-LiGothic-Medium.ttf",
            "./assets/fonts/Margin-DEMO.otf",
            "./assets/fonts/KeeponTruckin.ttf"
          ]
        }
      ],
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.241331490609-ru0e1cbhj9eb9g56i2if9009aa8uekff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a5d6e3ed-1ccf-4a77-be68-caacffe20c04"
      }
    }
  }
}
